# Copy to .env and fill in your values.
# Gemini / Google AI (required for AI features)
GOOGLE_API_KEY=your_google_api_key_here

# Optional: used if app reads from config.py
GEMINI_API_KEY=your_gemini_api_key_here
GCP_PROJECT_ID=your_gcp_project_id
FIRESTORE_PROJECT_ID=your_gcp_project_id
FIRESTORE_DATABASE=(default)
GCS_BUCKET=clarion-uploads
GCS_SIGNED_URL_TTL_SECONDS=3600
SIGNED_URL_SERVICE_ACCOUNT_EMAIL=clarion-runtime@your-project.iam.gserviceaccount.com
CLOUD_RUN_REGION=us-central1
CLOUD_TASKS_PROJECT_ID=your_gcp_project_id
CLOUD_TASKS_LOCATION=us-central1
CLOUD_TASKS_SERVICE_ACCOUNT_EMAIL=clarion-runner@your-project.iam.gserviceaccount.com
REPORT_TASK_QUEUE=clarion-report-jobs
RECONSTRUCTION_TASK_QUEUE=clarion-reconstruction-jobs
REPORT_WORKER_JOB_NAME=clarion-report-worker
RECONSTRUCTION_WORKER_JOB_NAME=clarion-reconstruction-worker
