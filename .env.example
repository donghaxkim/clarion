# Clarion — environment template
# Copy to .env and fill in values.

# Google AI / Gemini (used by gemini_client.py). Required for AI features.
GOOGLE_API_KEY=

# Alternative key name used by app/config.py for Gemini
GEMINI_API_KEY=

# Google Cloud Storage bucket for uploads (if using GCS)
GCS_BUCKET=clarion-uploads

# Local directory for uploaded files (default: /tmp/clarion-uploads)
UPLOAD_DIR=/tmp/clarion-uploads

# Set to 1 to use real Gemini API in tests (default: 0)
# CLARION_USE_REAL_API=0
