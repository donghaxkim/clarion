# Gemini / Vertex auth
GEMINI_API_KEY=
GOOGLE_API_KEY=
VERTEX_PROJECT_ID=
VERTEX_LOCATION=us-central1
GCP_PROJECT_ID=
FIRESTORE_PROJECT_ID=
FIRESTORE_DATABASE=(default)

# Reconstruction models
VEO_FAST_MODEL=veo-3.1-fast-generate-preview
VEO_FINAL_MODEL=veo-3.1-generate-preview

# Runtime toggles
VEO_ALLOW_FAKE=false
REPORT_ENABLE_PUBLIC_CONTEXT=true
REPORT_CONTEXT_CACHE_ENABLED=true

# Cloud storage and dispatch
GCS_BUCKET=
GCS_SIGNED_URL_TTL_SECONDS=3600
SIGNED_URL_SERVICE_ACCOUNT_EMAIL=
CLOUD_RUN_REGION=us-central1
CLOUD_RUN_JOBS_API_BASE_URL=https://run.googleapis.com
CLOUD_TASKS_PROJECT_ID=
CLOUD_TASKS_LOCATION=us-central1
CLOUD_TASKS_SERVICE_ACCOUNT_EMAIL=
REPORT_TASK_QUEUE=clarion-report-jobs
ANALYSIS_TASK_QUEUE=clarion-analysis-jobs
RECONSTRUCTION_TASK_QUEUE=clarion-reconstruction-jobs
REPORT_WORKER_JOB_NAME=clarion-report-worker
ANALYSIS_WORKER_JOB_NAME=clarion-analysis-worker
RECONSTRUCTION_WORKER_JOB_NAME=clarion-reconstruction-worker

# Report generation defaults
REPORT_TEXT_MODEL=gemini-3-pro-preview
REPORT_HELPER_MODEL=gemini-3-flash-preview
REPORT_IMAGE_MODEL=gemini-3-pro-image-preview
REPORT_SEARCH_MODEL=gemini-2.5-flash
REPORT_MAX_IMAGES=3
REPORT_MAX_RECONSTRUCTIONS=2
