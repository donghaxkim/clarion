# Local mode: no real Veo/GCS calls
# Gemini / Vertex auth (leave blank in local mode)
GEMINI_API_KEY=
GOOGLE_API_KEY=
VERTEX_PROJECT_ID=
VERTEX_LOCATION=us-central1

# Reconstruction models
VEO_FAST_MODEL=veo-3.1-fast-generate-preview
VEO_FINAL_MODEL=veo-3.1-generate-preview

# Local-only toggles
VEO_ALLOW_FAKE=false
GCS_ALLOW_LOCAL_FALLBACK=false
REPORT_ENABLE_PUBLIC_CONTEXT=true
REPORT_CONTEXT_CACHE_ENABLED=true

# Local artifact + metadata storage
GCS_BUCKET=
RECONSTRUCTION_JOB_STORE_PATH=.reconstruction_jobs.json
REPORT_JOB_STORE_PATH=.report_jobs.json
LOCAL_ARTIFACTS_DIR=.artifacts

# Report generation defaults
REPORT_TEXT_MODEL=gemini-3-pro-preview
REPORT_HELPER_MODEL=gemini-3-flash-preview
REPORT_IMAGE_MODEL=gemini-3-pro-image-preview
REPORT_SEARCH_MODEL=gemini-2.5-flash
REPORT_MAX_IMAGES=3
REPORT_MAX_RECONSTRUCTIONS=2
