{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Clarion Report Contract",
    "type": "object",
    "properties": {
        "report_id": {
            "type": "string"
        },
        "sections": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "id": {
                        "type": "string"
                    },
                    "type": {
                        "enum": [
                            "text",
                            "image",
                            "video",
                            "timeline"
                        ]
                    },
                    "content": {
                        "type": "string"
                    },
                    "media_urls": {
                        "type": "array",
                        "items": {
                            "type": "string"
                        }
                    },
                    "citations": {
                        "type": "array",
                        "items": {
                            "type": "object",
                            "properties": {
                                "document_id": {
                                    "type": "string"
                                },
                                "page_number": {
                                    "type": "integer"
                                },
                                "snippet": {
                                    "type": "string"
                                }
                            }
                        }
                    },
                    "confidence_score": {
                        "type": "number",
                        "minimum": 0,
                        "maximum": 1
                    },
                    "contradictions": {
                        "type": "array",
                        "items": {
                            "type": "string"
                        }
                    },
                    "counter_arguments": {
                        "type": "array",
                        "items": {
                            "type": "string"
                        }
                    }
                },
                "required": [
                    "id",
                    "type",
                    "content",
                    "confidence_score"
                ]
            }
        }
    },
    "required": [
        "report_id",
        "sections"
    ]
}